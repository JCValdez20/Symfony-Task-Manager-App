{% extends 'base.html.twig' %}

{% block title %}Welcome to TaskMaster{% endblock %}

{% block body %}
<div class="min-h-[80vh] flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl text-center space-y-8">
        
        <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-2xl bg-gray-50 border border-gray-200 shadow-sm mb-8 rotate-3 transition-transform hover:rotate-0 duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-gray-900">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V8.25H8.25m0 0h.375" />
            </svg>
        </div>

        <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight sm:text-7xl">
            Master your day. <br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-500 to-gray-900">
                Crush your tasks.
            </span>
        </h1>
        
        <p class="mt-6 text-xl text-gray-500 max-w-2xl mx-auto font-medium">
            A beautiful, lightning-fast workspace to organize your thoughts, track your progress, and get things done.
        </p>

        <div class="mt-10 flex justify-center">
            <a href="{{ path('app_task') }}" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-black rounded-xl overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-xl hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2">
                <span>Go to Workspace</span>
                
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transition-transform duration-300 group-hover:translate-x-1.5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </a>
        </div>
        
    </div>
</div>
{% endblock %}