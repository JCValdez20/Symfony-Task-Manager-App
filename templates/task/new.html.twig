{% extends 'base.html.twig' %}

{% block title %}Add New Task{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto mt-16 px-4">
    
    <div class="relative bg-white p-8 sm:p-10 rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
        
        <div class="flex items-center gap-4 mb-2">
            <div class="p-2.5 bg-gray-50 rounded-xl text-gray-700 border border-gray-200 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
            </div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Create a Task</h1>
        </div>
        
        <p class="text-gray-500 mb-8 ml-1">Add a new item to your task list below.</p>

        {{ form_start(form) }}
            
            <div class="space-y-6 bg-gray-50/50 p-6 rounded-2xl border border-gray-50">
                {{ form_row(form.title) }}
                {{ form_row(form.description) }}
            </div>

            <div class="mt-8 flex items-center gap-4 pt-2">
                {{ form_widget(form.save) }}
                
                <a href="{{ path('app_task') }}" class="inline-flex items-center justify-center px-6 py-2.5 font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 hover:text-gray-900 rounded-lg transition-all duration-200">
                    Cancel
                </a>
            </div>

        {{ form_end(form) }}

    </div>
</div>
{% endblock %}